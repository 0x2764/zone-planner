# ignore most dotfiles
.*
!.gitignore
!.github

# Generated by build.js — never committed. Run `node build.js` to produce it
# locally; CI builds and publishes it to GitHub Pages.
dist/

# Node (there are no dependencies, but just in case)
node_modules/

# e2e screenshots/artifacts, regenerated by npm run test:e2e
tests/__artifacts__/
